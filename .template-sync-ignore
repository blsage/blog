# Paths the blog → taylor-made sync never copies.
# The public template keeps its own (placeholder) version of each of these;
# everything else is mirrored from the blog on every push to main.

# Repo / build internals
/.git
/.github
/.next
/node_modules
/.template-sync-ignore

# Personal identity & registry — template ships placeholders
/README.md
/site.config.ts
/app/bio.mdx
/app/posts.json

# Personal posts (shared layout files at the (articles) root still sync)
/app/(articles)/*/

# Personal assets: music player tracklist + handwriting + all post media
/app/playlist.ts
/app/fonts/handwriting.ttf
/public/
